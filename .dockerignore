# Docker build context exclusions for the production image (Dockerfile).
# Keep this narrow and deliberate: anything NOT excluded here is sent to the
# Docker daemon on every build and is available to `COPY . .` in the builder
# stage. See infra/README.md for the full image design rationale.

# dependencies (reinstalled fresh in the `deps` stage via `npm ci`)
node_modules

# build output (regenerated by `next build` inside the builder stage)
.next
out
coverage
tsconfig.tsbuildinfo
next-env.d.ts

# test artifacts and tooling not needed to build or run the app
playwright-report
test-results
.lighthouseci
e2e

# version control and CI
.git
.github

# SDD planning artifacts and local agent state — not part of the app
openspec
.atl
.engram

# design mockups — referenced only in code comments, never imported at
# runtime or build time (verified: no import/require of design-reference/
# anywhere in src/, app/, or scripts/)
design-reference

# docs — not needed to build or run the app
docs
*.md

# secrets — never bake into an image layer
.env
.env.*
!.env.example

# misc
.DS_Store
